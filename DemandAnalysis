library(lubridate)
library(zoo)
library(xts)
library(forecast)
library(dplyr)

# Read the data into a data frame using the read.csv function which is built into R
df <- read.csv("C:/Users/aatwrigh/OneDrive - Hyster-Yale Group/Desktop/San Diego electricity demand challenge.csv")
head(df)

# When converting to date, we need to specify the format of the incoming character string the date is already formatted as.
df$New.Date <- as.Date(df$New.Date, format = "%m/%d/%Y")
str(df)

# Now we can format the date as needed to be able to properly use the grouping function later.
format(df$New.Date, "%Y-%m-%d")

# Check the structure to make sure everything is correct.
str(df)

# Now we group our New.Date by week using the floor_date function from the lubridate package
df_wgroup <- df %>%
  mutate(week_start = floor_date(df$New.Date, unit = "week")) %>%
  group_by(week_start) %>%
  summarise(total_rows = n(), total_demand = sum(Demand, na.rm = TRUE))
head(df_wgroup)

# Now we select the highest demand using the slice_max() function from the dplyr package
df_wgroup %>% slice_max(total_demand)

# This shows us that the highest demand week was 2022-09-04 with total demand of 560207

# Our goal in this section is to determine if the overall demand is increasing or decreasing over the entire time period of the data

df_model <- lm(Demand ~ New.Date, data = df)
summary(df_model)

# We can plot our original model as below, but we see it is very crowded and noisy
plot(df$New.Date, df$Demand, main="Demand by Date", xlab="Date", ylab="Demand")

# We improve this by instead plotting our Demand by week, which give a more clear representation of the data trends
plot(df_wgroup$week_start, df_wgroup$total_demand, main = "Demand by week", xlab = "Week", ylab = "Demand")
